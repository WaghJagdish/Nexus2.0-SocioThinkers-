APP_ENV=production
APP_NAME=Kisan Setu
APP_VERSION=2.0.0
DEBUG=false
LOG_LEVEL=INFO

HOST=0.0.0.0
PORT=8000
WORKERS=4

OPENAI_API_KEY=your-openai-or-nvidia-api-key-here
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=openai/gpt-oss-120b
EMBEDDING_MODEL=text-embedding-3-small
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=30

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

SARVAM_API_KEY=your-sarvam-api-key-here
SARVAM_TIMEOUT=30
SARVAM_RETRIES=3

BHUVAN_WMS_URL=https://bhuvan-vec2.nrsc.gov.in/bhuvan/wms
WEATHER_API_TIMEOUT=15
WEATHER_CACHE_TTL=3600

REDIS_URL=redis://localhost:6379/0
REDIS_TIMEOUT=5

CACHE_BACKEND=redis
CACHE_TTL_SECONDS=3600

MAX_RETRIES=3
REQUEST_TIMEOUT=30
IDEMPOTENCY_TTL=86400

CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
CORS_CREDENTIALS=true
CORS_METHODS=["*"]
CORS_HEADERS=["*"]

SECRET_KEY=replace-with-a-secure-random-string-min-32-chars
API_KEY_HEADER=X-API-Key
ENABLE_RATE_LIMIT=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

PROMETHEUS_ENABLED=true
SENTRY_DSN=

GENERATED_PDFS_DIR=./generated_pdfs
GENERATED_AUDIO_DIR=./generated_audio
SCHEME_DATA_DIR=./data/schemes
LOG_FILE_PATH=./logs/app.log
MAX_LOG_SIZE=104857600
BACKUP_COUNT=10
